{
  "version": 2,
  "functions": {
    "api/index.py": {
      "includeFiles": [
        "data/reference/gene_mapping.csv",
        "data/reference/kegg_cache/kegg_cgl_cgb.json",
        "data/reference/regulations.csv",
        "data/reference/rna_regulation.csv",
        "data/reference/AllOrganismsFiles/**",
        "data/reference/model/iCGB21FR.xml",
        "data/reference/model/iCGB21FR.omex",
        "data/reference/model/ecCGL1-main/ecCGL1-main/model/*.json",
        "data/reference/model/ecCGL1/model/*.json",
        "data/reference/imodulon/*.json",
        "data/reference/rna_seq_analysis_results.json",
        "data/reference/metabolic_models/**",
        "backend/models/**"
      ]
    }
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/reference/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/data/(.*)",
      "dest": "data/reference/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    },
    {
      "source": "/lib/vendor/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    }
  ]
}
